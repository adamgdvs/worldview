# Worldview — Environment Variables
# Copy to .env.local and fill in real values

# Google Maps (Photorealistic 3D Tiles)
VITE_GOOGLE_MAPS_API_KEY=

# Cesium Ion (terrain & imagery)
VITE_CESIUM_ION_TOKEN=

# OpenSky Network (aviation — OAuth2 client credentials)
# Server-side only — NOT exposed to browser bundle.
# NOTE: these are NOT your website login. Create an "API Client" under
# your account at https://opensky-network.org to get a client_id/secret.
# The app degrades gracefully to anonymous OpenSky (lower rate limits) without them.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# AISStream.io (maritime WebSocket)
VITE_AISSTREAM_API_KEY=

# n2yo.com (satellite TLE & above queries)
VITE_N2YO_API_KEY=

# Space-Track.org (optional — notable-satellite TLE lookups; CelesTrak covers groups)
VITE_SPACETRACK_IDENTITY=
VITE_SPACETRACK_PASSWORD=

# Windy webcams (optional — CCTV supplement)
VITE_WINDY_WEBCAMS_KEY=
