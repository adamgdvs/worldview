{
  "framework": "vite",
  "buildCommand": "tsc -b && vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/opensky-token", "destination": "/api/opensky-token" },
    { "source": "/opensky/(.*)", "destination": "/api/opensky" },
    { "source": "/n2yo/(.*)", "destination": "/api/n2yo" },
    { "source": "/celestrak/(.*)", "destination": "/api/celestrak" },
    { "source": "/gpsjam/(.*)", "destination": "/api/gpsjam" },
    { "source": "/firms/(.*)", "destination": "/api/firms" },
    { "source": "/adsbfi/(.*)", "destination": "/api/adsbfi" }
  ]
}
